rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      // Prioritize database role Check
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin" ||
         request.auth.token.email == "admin@aura.com"); // Hardcoded fallback for initial setup
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    match /users/{userId} {
      // Allow users to get their own profile.
      allow get: if isAuthenticated() && request.auth.uid == userId;
      // Allow admins to list all profiles and get any specific profile.
      allow list: if isAdmin();
      allow get: if isAdmin();
      // Allow profile creation/update for the owner or the admin.
      allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    match /carts/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }
  }
}
